# ─────────────────────────────────────────────────────────────────────
# Variables de entorno de SUPERLATIVO CRM
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo como .env (sin la palabra ".example") y rellena
# los valores. NUNCA subas el archivo .env real a GitHub.
# ─────────────────────────────────────────────────────────────────────

# OBLIGATORIA — Base de datos
# ─────────────────────────────────────────────────────────────────────
# Para PROBAR EN TU COMPU (local), usa SQLite:
#   DATABASE_URL="file:./dev.db"
#
# Para PUBLICAR EN VERCEL, usa Postgres GRATIS sin tarjeta:
#   1) Entra a https://vercel.com/dashboard
#   2) Pestaña "Storage" → "Create Database" → elige "Postgres"
#      (también sirve Neon: https://neon.tech, plan Free)
#   3) Copia la URL que te dé (empieza con "postgres://...")
#   4) Pégala aquí abajo Y en Vercel → Settings → Environment Variables
DATABASE_URL="file:./dev.db"

# OBLIGATORIA — Secreto para sesiones de login
# ─────────────────────────────────────────────────────────────────────
# Texto largo y aleatorio para firmar las cookies de sesión.
# Generar uno en https://generate-secret.vercel.app/32  o ejecutando:
#   openssl rand -base64 32
AUTH_SECRET="cambia-este-valor-por-uno-aleatorio-largo-y-secreto"

# URL pública del sitio (Vercel la pone sola en producción).
# Local: déjala así. Producción: tu liga, ej. https://mi-crm.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# OPCIONAL — Asistente con IA (Claude/Anthropic)
# ─────────────────────────────────────────────────────────────────────
# Si NO la pones, el asistente cae a plantillas inteligentes locales.
# Sacar llave en https://console.anthropic.com/  → API Keys
ANTHROPIC_API_KEY=

# OPCIONAL — Google Calendar / Meet
# ─────────────────────────────────────────────────────────────────────
# Si NO las pones, la cita se guarda igual en la base y se muestra un
# aviso amable de "conecta Google" sin romper nada.
# 1) Entra a https://console.cloud.google.com  → crea un proyecto
# 2) APIs y servicios → habilita "Google Calendar API"
# 3) Crea credenciales OAuth 2.0 (tipo "Web app")
# 4) URL de redirección autorizada:
#    http://localhost:3000/api/google/callback  (y la de Vercel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OPCIONAL — Almacenamiento de archivos grandes
# ─────────────────────────────────────────────────────────────────────
# Por defecto los archivos pequeños se guardan dentro de la base (≤4 MB).
# Si quieres archivos más grandes, activa Vercel Blob (gratis, sin tarjeta):
# Vercel → Storage → Create Database → "Blob".
BLOB_READ_WRITE_TOKEN=
